generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String          @id @default(uuid())
  email          String          @unique
  transactions   Transaction[]
  budgetSettings BudgetSettings?
  goals          Goal[]
  createdAt      DateTime        @default(now())
}

model Transaction {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount      Decimal  @db.Decimal(12, 2)
  description String
  type        String   // 'income' | 'expense'
  category    String?  // 'fixed_expenses' | 'variable_expenses' | 'savings' | 'tithe' | 'fiv'
  date        DateTime @default(now())
  isAutomatic Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model BudgetSettings {
  id                      String   @id @default(uuid())
  userId                  String   @unique
  user                    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fixedExpensesPercent    Int      @default(50)
  variableExpensesPercent Int      @default(20)
  savingsPercent          Int      @default(10)
  tithePercent            Int      @default(10)
  fivPercent              Int      @default(10)
  monthlyIncome           Decimal? @db.Decimal(12, 2)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
}

model Goal {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name          String
  targetAmount  Decimal  @db.Decimal(12, 2)
  currentAmount Decimal  @default(0) @db.Decimal(12, 2)
  deadline      DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
